# Vault Router keeper — copy to .env (gitignored). Never commit real values.

KEEPER_RPC_URL=
KEEPER_VAULT_ADDRESS=
KEEPER_CHAIN_ID=42161            # Arbitrum One

# Name of the env var that holds the curator private key. The key itself is
# read from THAT variable at runtime — it is never stored in this file or code.
KEEPER_KEY_ENV=KEEPER_PRIVATE_KEY

# Dry-run logs intended actions without signing/sending (LogExecutor). Set false
# to sign + send with the curator key via LocalExecutor — this also requires
# KEEPER_RPC_URL and KEEPER_VAULT_ADDRESS. With an RPC + vault set, perceive uses
# the live ChainReader regardless of this flag (reads are always safe).
KEEPER_DRY_RUN=true

# Which decision brain to run: "stub" echoes current on-chain targets (default);
# "gauntlet-lite" runs the risk-gated water-fill allocator.
KEEPER_BRAIN=stub

# Cadence (Go duration strings)
KEEPER_POLL_INTERVAL=30s
KEEPER_GUARD_INTERVAL=5m
KEEPER_HARVEST_INTERVAL=6h
KEEPER_REBALANCE_MIN_INTERVAL=1h

# ---------------------------------------------------------------------------
# Risk signal layer (gauntlet-lite brain only). "static" (default) preserves the
# closed-form EL floor for every strategy. "composite" routes each StrategyID to
# its LIVE adapter (Pendle on-chain / Aave ProtocolDataProvider / Credora). Every
# adapter degrades to no-data (closed-form floor) when its address/endpoint below
# is empty — "composite" with nothing configured behaves exactly like "static".
KEEPER_RISK_PROVIDER=static

# Aave V3 live reserve-risk reader (utilization / paused / frozen / supply cap).
# DATA_PROVIDER is the Aave V3 ProtocolDataProvider; on Arbitrum One it is
# 0x243Aa95cAC2a25651eda86e80bEe66114413c43b (aave-dao/aave-address-book). ASSET
# is the reserve to query == Vault.asset() (USDC). STRATEGY_IDS is a comma-
# separated list of 32-byte hex StrategyIDs the Aave adapter owns. All empty =>
# Aave adapter returns no-data.
KEEPER_AAVE_DATA_PROVIDER=
KEEPER_AAVE_ASSET=
KEEPER_AAVE_STRATEGY_IDS=

# Pendle PT live oracle (drives both the maturity-structural liquidity gate and
# the fixed-to-maturity implied-APY overlay). ORACLE is the shared PendlePYLpOracle
# address. MARKETS is a comma-separated list of "id=market:pt:duration" entries,
# where id is a 32-byte hex StrategyID, market/pt are addresses and duration is the
# TWAP window in seconds, e.g.:
#   KEEPER_PENDLE_MARKETS=0xabc...=0xMarket:0xPT:900
KEEPER_PENDLE_ORACLE=
KEEPER_PENDLE_MARKETS=

# Credora (Morpho facet) GraphQL rating feed. ENDPOINT is OPERATOR-SUPPLIED — the
# public Morpho API (api.morpho.org/graphql) exposes NO rating field, so do NOT
# point this there; leave empty to keep the Credora adapter dormant (no-data). The
# real Credora-by-RedStone API is auth-gated: the key is read from the env var
# NAMED by KEEPER_CREDORA_API_KEY_ENV (default KEEPER_CREDORA_API_KEY) and sent as
# a Bearer token. MARKETS is "id=marketKey" CSV (id = 32-byte hex StrategyID).
KEEPER_CREDORA_ENDPOINT=
KEEPER_CREDORA_API_KEY_ENV=KEEPER_CREDORA_API_KEY
KEEPER_CREDORA_MARKETS=
